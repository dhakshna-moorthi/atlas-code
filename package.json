{
  "name": "atlas-code",
  "displayName": "Atlas Code",
  "description": "An AI-powered coding agent for VS Code. Read, write, debug, and refactor your codebase using natural language.",
  "license": "MIT",
  "icon": "icon.png",
  "version": "0.0.5",
  "publisher": "dhakshnamoorthi",
  "homepage": "https://github.com/dhakshna-moorthi/atlas-code",
  "bugs": {
    "url": "https://github.com/dhakshna-moorthi/atlas-code/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dhakshna-moorthi/atlas-code"
  },
  "extensionKind": ["ui"],
  "pricing": "Free",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atlas.start",
        "title": "Atlas: Open Agent"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atlas-sidebar",
          "title": "Atlas Code",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "atlas-sidebar": [
        {
          "type": "webview",
          "id": "atlas.chatView",
          "name": "Atlas Agent",
          "icon": "media/logo.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.21",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
